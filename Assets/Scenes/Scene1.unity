          m_Mode: 5
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: "Essa \xE9 a entrada principal. Se certifique que sempre
              tem carrinhos e cestas dispon\xEDveis."
            m_BoolArgument: 0
          m_CallState: 2
    - m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 359021782}
          m_TargetAssemblyTypeName: TMPro.TextMeshProUGUI, Unity.TextMeshPro
          m_MethodName: set_text
          m_Mode: 5
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: "Esse corredor \xE9 onde o pessoal mais compra produtos,
              voc\xEA ter\xE1 que reestocar com frequ\xEAncia!"
            m_BoolArgument: 0
          m_CallState: 2
    - m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 359021782}
          m_TargetAssemblyTypeName: TMPro.TextMeshProUGUI, Unity.TextMeshPro
          m_MethodName: set_text
          m_Mode: 5
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: "Nossos freezers! Fora reestocar de vez em quando,
              voc\xEA precisa fechar as portas, devolver produtos para que n\xE3o
              estraguem e enxugar o ch\xE3o caso necess\xE1rio."
            m_BoolArgument: 0
          m_CallState: 2
    - m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 359021782}
          m_TargetAssemblyTypeName: TMPro.TextMeshProUGUI, Unity.TextMeshPro
          m_MethodName: set_text
          m_Mode: 5
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: "Produtos um pouco mais pesados ou fr\xE1geis. Reestocar
              aqui pode ser um pouco mais demorado. Cuidado com a coluna!"
            m_BoolArgument: 0
          m_CallState: 2
    - m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 359021782}
          m_TargetAssemblyTypeName: TMPro.TextMeshProUGUI, Unity.TextMeshPro
          m_MethodName: set_text
          m_Mode: 5
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: "Nossos produtos fresquinhos! Se certifique que os
              produtos est\xE3o no lugar correto e remova qualquer alimento apodrecendo."
            m_BoolArgument: 0
          m_CallState: 2
    - m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 359021782}
          m_TargetAssemblyTypeName: TMPro.TextMeshProUGUI, Unity.TextMeshPro
          m_MethodName: set_text
          m_Mode: 5
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: "E a parte mais importante! Passe os itens com cuidado
              para n\xE3o cobrar nem a mais, nem a menos. Aten\xE7\xE3o na hora do
              troco!"
            m_BoolArgument: 0
          m_CallState: 2
